{
  "permissions": {
    "allow": [
      "Bash(python3 -m http.server 8080)",
      "Bash(echo \"Server started, PID: $!\")",
      "Bash('/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' --headless=new --disable-gpu --no-sandbox --screenshot=/private/tmp/mobile-430-full.png --window-size=430,5000 --hide-scrollbars http://localhost:8080)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code finished task, please check\" with title \"Claude Code\"' -e 'beep'"
          }
        ]
      }
    ]
  }
}
